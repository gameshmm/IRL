{
  "rtmp": {
    "port": 1935,
    "chunk_size": 60000,
    "gop_cache": true,
    "ping": 5,
    "ping_timeout": 60
  },
  "http": {
    "port": 8000,
    "allow_origin": "*",
    "mediaroot": "./media"
  },
  "trans": {
    "ffmpeg": "/usr/bin/ffmpeg",
    "tasks": [
      {
        "app": "live",
        "hls": true,
        "hlsFlags": "[hls_time=2:hls_list_size=3:hls_flags=delete_segments]",
        "dash": false,
        "dashFlags": "[seg_duration=2:window_size=3:extra_window_size=5]"
      }
    ]
  },
  "stream": {
    "app": "live"
  }
}
